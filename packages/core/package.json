{
  "name": "@repo/core",
  "type": "module",
  "private": "true",
  "scripts": {
    "build": "tsdown",
    "try": "bun run src/try.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint --cache"
  },
  "exports": {
