{
  "name": "ultra-bun",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:home": "bun --elide-lines 0 --filter @repo/home dev",
    "dev:web": "bun --elide-lines 0 --filter @repo/web dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "format": "prettier . --write --cache",
    "format:check": "prettier . --check --cache",
    "check": "turbo run check-types lint && bun run format:check",
    "ui:add": "bun --elide-lines 0 --filter @repo/ui shadcn:add"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*",
      "scripts/*"
    ],
    "catalog": {
      "@clack/prompts": "^1.2.0",
      "@tanstack/react-router": "^1.168.22",
      "@tanstack/react-start": "^1.167.41",
      "@types/bun": "^1.3.12",
      "@types/node": "^25.6.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "eslint": "^10.2.0",
      "jsonc-parser": "^3.3.1",
      "lucide-react": "^1.8.0",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "tailwindcss": "^4.2.2",
      "tsdown": "^0.21.7",
      "typescript": "^6.0.2",
      "vite": "^8.0.8",
      "zod": "^4.3.6"
    }
  },
  "devDependencies": {
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.12"
}
