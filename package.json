{
  "name": "ultra-bun",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "format": "prettier . --write --cache",
    "format:check": "prettier . --check --cache",
    "check": "turbo run check-types lint && bun run format:check",
    "gen": "bun run \"scripts\\gen\\src\\index.ts\""
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*",
      "scripts/*"
    ],
    "catalog": {
      "@clack/prompts": "^1.2.0",
      "@types/bun": "^1.3.12",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "eslint": "^10.2.0",
      "jsonc-parser": "^3.3.1",
      "lucide-react": "^1.8.0",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "tailwindcss": "^4.2.2",
      "tsdown": "^0.21.7",
      "typescript": "^6.0.2",
      "zod": "^4.3.6"
    }
  },
  "devDependencies": {
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.12"
}
