{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!migrations/**",
        "!eslint.config.js",
        "!drizzle.config.ts",
        "!.env.example",
        "!README.md",
        "!components.json"
      ],
      "outputs": ["dist/**"],
      "outputLogs": "errors-only"
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!migrations/**",
        "!.env.example",
        "!README.md",
        "!components.json"
      ],
      "outputLogs": "errors-only"
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!migrations/**",
        "!.env.example",
        "!README.md",
        "!components.json"
      ],
      "outputs": [".eslintcache"],
      "outputLogs": "errors-only"
    }
  }
}
